# =============================================================================
# BSC 节点环境变量模板
#
# 覆盖 .env 并重启（在 bsc-node 目录下执行）：
#
#   cp -f .env.example .env && docker compose down && docker compose up -d
#
# 仅覆盖 .env、暂不重启：
#
#   cp -f .env.example .env
#
# 覆盖前请确认 HTTP_BIND_ADDR / WS_BIND_ADDR 是否为当前机器 Tailscale IP：
#   tailscale ip -4
#
# 应用配置后验证：
#   docker compose logs --tail 30 bsc | grep -E 'nat=|triesInMemory|Started P2P'
#   docker exec bsc-node geth attach --datadir /bsc/node --exec "net.peerCount"
# =============================================================================

# BSC 镜像版本（需 >= 1.7.2）
BSC_IMAGE=ghcr.io/bnb-chain/bsc:1.7.3

# 同步模式（四选一）：
#   fast   - 48Club FastNode 快照约 415GB（默认，推荐，1TB 磁盘够用）
#   snap   - 从网络 snap 同步，磁盘逐渐增长至 ~3TB+
#   incr   - 官方增量快照，稳态约 120~200GB
#   pruned - 官方裁剪快照约 1.6TB
BSC_SYNC_MODE=fast

# --- NAT / P2P ---
# 家里公网 IP 会变、走 WiFi / 对称 NAT 时：必须用 NAT_MODE=any，不要用 extip 固定 IP。
#   any         自动发现公网 IP + UPnP（动态 IP 推荐；IP 变了会自动更新 enode）
#   extip       仅固定公网 IP 且有线稳定出口时用；IP 会变则 peer 连不上，勿用
#
# 动态 IP 下 inbound 几乎为 0 是正常的，靠 StaticNodes 主动外连 + refresh-static-nodes.sh 即可追块。
# RPC 走 Tailscale，与 P2P 无关。WiFi 易断流，节点尽量插网线。
NAT_MODE=any

# 仅 NAT_MODE=extip 时需要；公网 IP 不稳定时不要启用
# NAT_EXTIP=

P2P_PORT=30303

# --- Geth 性能 / trace（方案 A：fast 模式）---
# trace 请求需带 reexec:15000，例如 debug.traceBlockByNumber(n, {reexec:15000})
CACHE_MB=2048
TRIES_IN_MEMORY=15000
HISTORY_STATE=15000

# --- 容器内存（按物理内存调整）---
# 32G 物理内存：MEM_LIMIT=32g, MEMSWAP_LIMIT=48g
# 64G 物理内存：MEM_LIMIT=56g, MEMSWAP_LIMIT=64g
MEM_LIMIT=32g
MEMSWAP_LIMIT=48g
MEM_RESERVATION=16g

# --- Peer ---
MAX_PEERS=120
MAX_PEND_PEERS=100

# 可选：覆盖默认 bootnodes（逗号分隔 enode，一般无需修改）
# BSC_BOOTNODES=

# --- RPC（Tailscale 内网，勿暴露公网）---
# 执行 tailscale ip -4 获取当前 IP，覆盖 .env 前请核对
HTTP_BIND_ADDR=100.90.122.73
WS_BIND_ADDR=100.90.122.73
HTTP_VHOSTS=localhost,127.0.0.1,100.90.122.73

HTTP_PORT=8545
WS_PORT=8546
