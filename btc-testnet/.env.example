# 复制为 .env：cp .env.example .env

BITCOIN_VERSION=31.0

# Signet 端口（与主网 8333/8332 不冲突）
P2P_PORT=38333
RPC_PORT=38332

# RPC 宿主机绑定（docker 端口映射：RPC_BIND_ADDR:RPC_PORT → 容器 8332）
#
# 127.0.0.1  — 仅本机，本地调试
# 云服务器   — 填该机器的「内网/私有 IP」（控制台可见，如 10.x、172.x），供同事经 VPN/VPC 访问
#              勿填 127.0.0.1；一般也不填公网 IP（用内网 IP + 安全组即可）
#
# 查内网 IP：ip -4 addr | grep inet
RPC_BIND_ADDR=127.0.0.1

# 开发同事连接的 RPC 地址（通常与 RPC_BIND_ADDR 相同；有内网域名时可填域名）
# RPC_HOST=10.0.1.23
