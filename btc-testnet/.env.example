# 复制为 .env：cp .env.example .env
# RPC_BIND_ADDR 说明见 README.md「RPC_BIND_ADDR」

BITCOIN_VERSION=31.0
# 默认 bitcoin/bitcoin:<版本>；也可指定镜像加速完整地址
BITCOIN_IMAGE=bitcoin/bitcoin:31.0

# Signet 端口（与主网 8333/8332 不冲突）
P2P_PORT=38333
RPC_PORT=38332

# RPC 宿主机绑定 → 容器 38332（仅影响谁能连 RPC，不影响 P2P 同步）
# 127.0.0.1        仅本机（默认）
# 10.x / 100.x     云内网 IP 或 Tailscale IP，供团队远程访问
RPC_BIND_ADDR=127.0.0.1

# 给同事文档用的 RPC 地址（通常与 RPC_BIND_ADDR 相同）
# RPC_HOST=100.75.33.104
