# 复制为 .env 后按需修改：
#   cp .env.example .env

# 官方镜像（https://github.com/base/node/releases）
BASE_NODE_IMAGE=ghcr.io/base/node-reth
BASE_NODE_VERSION=v1.1.1

# 网络：mainnet | sepolia
NETWORK=mainnet

# 宿主机映射端口（RPC 默认仅绑定 127.0.0.1）
HTTP_PORT=8545
WS_PORT=8546
CONSENSUS_RPC_PORT=7545
P2P_EXEC_PORT=30303
P2P_CONSENSUS_PORT=9222
EXEC_METRICS_PORT=7301
CONSENSUS_METRICS_PORT=7300
CONSENSUS_PPROF_PORT=6060
