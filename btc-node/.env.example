# 复制为 .env 后按需修改：
#   cp .env.example .env

# Bitcoin Core 镜像版本（Docker Hub: bitcoin/bitcoin）
BITCOIN_VERSION=31.0

# 宿主机映射端口
P2P_PORT=8333
RPC_PORT=8332

# RPC 绑定地址（Docker 端口映射）
#   127.0.0.1         仅本机访问（默认）
#   100.x.x.x         Tailscale IP，供内网其他设备访问（需配合 bitcoin.conf rpcallowip）
# 获取 Tailscale IP: tailscale ip -4
RPC_BIND_ADDR=127.0.0.1
